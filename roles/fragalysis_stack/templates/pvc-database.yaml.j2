---
kind: PersistentVolumeClaim
apiVersion: v1
metadata:
  name: database
  namespace: {{ stack_namespace }}
spec:
  accessModes:
  - ReadWriteOnce
{# A blank (whitespace-only) class omits the field so the cluster's #}
{# default StorageClass is used; setting it to '' would instead    #}
{# disable dynamic provisioning.                                    #}
{% if database_vol_storageclass | trim | length > 0 %}
  storageClassName: '{{ database_vol_storageclass | trim }}'
{% endif %}
  resources:
    requests:
      storage: '{{ database_vol_size_g }}Gi'
